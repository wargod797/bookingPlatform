<config xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xmlns="http://www.ehcache.org/v3"
        xmlns:jsr107="http://www.ehcache.org/v3/jsr107"
        xsi:schemaLocation="
          http://www.ehcache.org/v3 http://www.ehcache.org/schema/ehcache-core.xsd
          http://www.ehcache.org/v3/jsr107 http://www.ehcache.org/schema/ehcache-107-ext.xsd">
    <cache alias="movies">
        <key-type>java.lang.Long</key-type>
        <value-type>com.example.booking.model.Movie</value-type>
        <expiry>
            <ttl unit="minutes">60</ttl>
        </expiry>
        <resources>
            <heap unit="entries">1000</heap>
            <offheap unit="MB">10</offheap>
        </resources>
    </cache>
    <cache alias="locationDirectory">
        <key-type>java.lang.String</key-type>
        <value-type>java.util.LinkedHashMap</value-type>
        <expiry>
            <ttl unit="minutes">180</ttl>
        </expiry>
        <resources>
            <heap unit="entries">20</heap>
            <offheap unit="MB">5</offheap>
        </resources>
    </cache>
    <cache alias="locationCountries">
        <key-type>java.lang.String</key-type>
        <value-type>java.util.ArrayList</value-type>
        <expiry>
            <ttl unit="minutes">180</ttl>
        </expiry>
        <resources>
            <heap unit="entries">10</heap>
            <offheap unit="MB">2</offheap>
        </resources>
    </cache>
    <cache alias="locationCities">
        <key-type>java.lang.String</key-type>
        <value-type>java.util.List</value-type>
        <expiry>
            <ttl unit="minutes">180</ttl>
        </expiry>
        <resources>
            <heap unit="entries">100</heap>
            <offheap unit="MB">5</offheap>
        </resources>
    </cache>
</config>
